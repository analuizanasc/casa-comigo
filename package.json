{
  "name": "casa-comigo-api",
  "version": "1.0.0",
  "description": "API REST para gestão colaborativa de tarefas domésticas",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:api": "mocha src/tests/api/index.test.js --timeout 10000 --exit --reporter mochawesome --reporter-options reportDir=src/tests/api/reports,reportFilename=relatorio-api,overwrite=true,html=true,json=true",
    "test:api:simples": "mocha src/tests/api/index.test.js --timeout 10000 --exit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "chai": "^4.5.0",
    "jest": "^29.7.0",
    "mocha": "^11.7.6",
    "mochawesome": "^7.1.4",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/services/**/*.js"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageDirectory": "coverage",
    "clearMocks": true
  }
}
